#!/bin/bash

set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "usage: game-run <launcher> [args...]" >&2
  exit 64
fi

# Electron apps launched from an editor terminal must not inherit Node mode.
unset ELECTRON_RUN_AS_NODE

on_ac_power() {
  local supply

  for supply in /sys/class/power_supply/*; do
    [ -r "$supply/type" ] || continue
    [ "$(tr -d '\n' < "$supply/type")" = "Mains" ] || continue
    [ -r "$supply/online" ] || continue
    [ "$(tr -d '\n' < "$supply/online")" = "1" ] && return 0
  done

  return 1
}

if on_ac_power; then
  current_mode="$(optimus-manager --print-mode 2>/dev/null || true)"
  current_mode="${current_mode##*: }"

  if [ "$current_mode" = "nvidia" ]; then
    exec env \
      -u __NV_PRIME_RENDER_OFFLOAD \
      -u __VK_LAYER_NV_optimus \
      -u __GLX_VENDOR_LIBRARY_NAME \
      -u __GL_SYNC_DISPLAY_DEVICE \
      __GL_SYNC_TO_VBLANK=0 \
      "$@"
  fi

  if [ -x "$HOME/.local/bin/prime-sync-run" ]; then
    PRIME_SYNC_TO_VBLANK=0 exec "$HOME/.local/bin/prime-sync-run" "$@"
  fi

  if command -v prime-run >/dev/null 2>&1; then
    exec prime-run "$@"
  fi
fi

exec "$@"

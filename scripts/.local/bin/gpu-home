#!/bin/bash

set -euo pipefail

current_mode="$(optimus-manager --print-mode 2>/dev/null || true)"
current_mode="${current_mode##*: }"

if [ "$current_mode" = "nvidia" ]; then
	echo "Already using NVIDIA mode."
	exit 0
fi

exec optimus-manager --switch nvidia 2> >(grep -vE '^which: no (sv|rc-status|s6-svstat) in ' >&2)

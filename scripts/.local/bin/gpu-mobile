#!/bin/bash

set -euo pipefail

current_mode="$(optimus-manager --print-mode 2>/dev/null || true)"
current_mode="${current_mode##*: }"

if [ "$current_mode" = "hybrid" ]; then
  echo "Already using hybrid mode."
  exit 0
fi

echo "Switching to hybrid mode for the next login."
echo "This closes the current graphical session after confirmation."
exec optimus-manager --switch hybrid
